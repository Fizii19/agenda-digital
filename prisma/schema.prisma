generator client {
  provider = "prisma-client"
  output   = "../lib/generated/client"
}

datasource db {
  provider = "mysql"
}

model agenda {
  id         String       @id
  kelas      String
  tanggal    String
  createdBy  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  user       user         @relation(fields: [createdBy], references: [id], map: "Agenda_createdBy_fkey")
  agendaitem agendaitem[]

  @@index([createdBy], map: "Agenda_createdBy_fkey")
}

model agendaitem {
  id         String  @id
  jamMulai   String
  jamSelesai String
  kegiatan   String
  keterangan String?
  agendaId   String
  agenda     agenda  @relation(fields: [agendaId], references: [id], onDelete: Cascade, map: "AgendaItem_agendaId_fkey")

  @@index([agendaId], map: "AgendaItem_agendaId_fkey")
}

model kelas {
  id             String        @id
  nama           String
  tingkat        Int
  jurusan        String
  waliKelas      String
  jumlahSiswa    Int
  tahunAjaran    String
  tahunAjaranId  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  tahunajaran    tahunajaran?  @relation(fields: [tahunAjaranId], references: [id], onDelete: SetNull, map: "Kelas_tahunAjaranId_fkey")
  subjects       subject[]
  riwayatSiswa   siswakelasriwayat[]
  siswaAktif      user[]        @relation("UserActiveKelas")
  presensiGuruMapel presensigurumapel[]

  @@index([tahunAjaranId], map: "Kelas_tahunAjaranId_fkey")
  @@unique([nama, tahunAjaranId], map: "Kelas_nama_tahunAjaranId_key")
}

model tahunajaran {
  id        String   @id
  nama      String   @unique(map: "TahunAjaran_nama_key")
  aktif     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  kelas     kelas[]
  riwayatSiswa siswakelasriwayat[]
}

model subject {
  id        String   @id
  nama      String
  kode      String?
  guruId    String
  kelasId   String
  jam       Int      @default(2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  guru      user     @relation(fields: [guruId], references: [id], map: "Subject_guruId_fkey")
  kelas     kelas    @relation(fields: [kelasId], references: [id], map: "Subject_kelasId_fkey")
  schedules schedule[]

  @@unique([nama, kelasId], map: "Subject_nama_kelasId_key")
  @@index([guruId], map: "Subject_guruId_fkey")
  @@index([kelasId], map: "Subject_kelasId_fkey")
}

model ruangan {
  id        String   @id
  nama      String   @unique(map: "Ruangan_nama_key")
  tipe      String
  kapasitas Int?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  schedules schedule[]
}

model schedule {
  id          String   @id
  hari        String   // Senin, Selasa, Rabu, Kamis, Jumat, Sabtu
  jamMulai    String   // HH:mm
  jamSelesai  String   // HH:mm
  subjectId   String
  ruanganId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subject     subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade, map: "Schedule_subjectId_fkey")
  ruangan     ruangan? @relation(fields: [ruanganId], references: [id], onDelete: SetNull, map: "Schedule_ruanganId_fkey")
  presensiGuruMapel presensigurumapel[]

  @@index([subjectId], map: "Schedule_subjectId_fkey")
  @@index([ruanganId], map: "Schedule_ruanganId_fkey")
}

model user {
  id        String    @id
  name      String
  email     String?   @unique(map: "User_email_key")
  nis       String?   @unique(map: "User_nis_key")
  nip       String?   @unique(map: "User_nip_key")
  status    String    @default("Aktif")
  password  String    @default("password123")
  role      user_role
  avatar    String?
  kelas     String?
  kelasId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  agenda    agenda[]
  subjects  subject[]
  additionalRoles userrole[] @relation("UserAdditionalRoles")
  assignedRoles userrole[]   @relation("UserAssignedRoles")
  riwayatKelas siswakelasriwayat[]
  kelasAktif kelas?    @relation("UserActiveKelas", fields: [kelasId], references: [id], onDelete: SetNull, map: "User_kelasId_fkey")
  presensiGuruMapel presensigurumapel[] @relation("PresensiGuruMapelGuru")
  inputPresensiGuruMapel presensigurumapel[] @relation("PresensiGuruMapelInputBy")

  @@index([kelasId], map: "User_kelasId_fkey")
}

model userrole {
  id             String    @id
  userId         String
  role           user_role
  assignedBy     String?
  createdAt      DateTime  @default(now())
  user           user      @relation("UserAdditionalRoles", fields: [userId], references: [id], onDelete: Cascade, map: "UserRole_userId_fkey")
  assignedByUser user?     @relation("UserAssignedRoles", fields: [assignedBy], references: [id], onDelete: SetNull, map: "UserRole_assignedBy_fkey")

  @@unique([userId, role], map: "UserRole_userId_role_key")
  @@index([assignedBy], map: "UserRole_assignedBy_fkey")
}

model siswakelasriwayat {
  id             String       @id
  siswaId        String
  kelasId        String?
  kelasNama      String
  tingkat        Int
  jurusan        String
  waliKelas      String
  tahunAjaran    String
  tahunAjaranId  String?
  status         String       @default("aktif")
  tanggalMasuk   DateTime     @default(now())
  tanggalKeluar  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  siswa          user         @relation(fields: [siswaId], references: [id], onDelete: Cascade, map: "SiswaKelasRiwayat_siswaId_fkey")
  kelas          kelas?       @relation(fields: [kelasId], references: [id], onDelete: SetNull, map: "SiswaKelasRiwayat_kelasId_fkey")
  tahunajaran    tahunajaran? @relation(fields: [tahunAjaranId], references: [id], onDelete: SetNull, map: "SiswaKelasRiwayat_tahunAjaranId_fkey")

  @@unique([siswaId, tahunAjaran], map: "SiswaKelasRiwayat_siswaId_tahunAjaran_key")
  @@index([kelasId], map: "SiswaKelasRiwayat_kelasId_fkey")
  @@index([tahunAjaranId], map: "SiswaKelasRiwayat_tahunAjaranId_fkey")
}

model presensigurumapel {
  id         String   @id
  tanggal    String
  kelasId    String
  scheduleId String
  guruId     String
  status     String
  keterangan String?
  inputBy    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  kelas      kelas    @relation(fields: [kelasId], references: [id], onDelete: Cascade, map: "PresensiGuruMapel_kelasId_fkey")
  schedule   schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade, map: "PresensiGuruMapel_scheduleId_fkey")
  guru       user     @relation("PresensiGuruMapelGuru", fields: [guruId], references: [id], onDelete: Cascade, map: "PresensiGuruMapel_guruId_fkey")
  penginput  user     @relation("PresensiGuruMapelInputBy", fields: [inputBy], references: [id], onDelete: Cascade, map: "PresensiGuruMapel_inputBy_fkey")

  @@unique([tanggal, scheduleId], map: "PresensiGuruMapel_tanggal_scheduleId_key")
  @@index([kelasId], map: "PresensiGuruMapel_kelasId_fkey")
  @@index([scheduleId], map: "PresensiGuruMapel_scheduleId_fkey")
  @@index([guruId], map: "PresensiGuruMapel_guruId_fkey")
  @@index([inputBy], map: "PresensiGuruMapel_inputBy_fkey")
}

enum user_role {
  admin
  sekretaris
  walikelas
  pimpinan
  siswa
  guru
}
